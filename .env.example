# Backend Environment Variables
# Copy this file to .env and update the values

# Server Port

# MongoDB Connection String
# For local development:
# MONGO_URI=mongodb://localhost:27017/seoulbrewcafe

# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/seoulbrewcafe

# JWT Secret (use a strong random string in production)

# Frontend URLs (comma-separated for CORS)
# For local development:


# For production (multiple URLs):
# FRONTEND_URL=https://seoul-brew-cafe-frontend.vercel.app,https://seoulbrewcafes.netlify.app

FRONTEND_URL=http://localhost:5173
JWT_SECRET=your_super_secret_jwt_key_change_this
PORT=5000

